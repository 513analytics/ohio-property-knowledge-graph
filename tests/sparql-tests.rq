# Ontology Validation Tests
# Run these SPARQL ASK queries to validate the ontology structure
# All queries should return TRUE

PREFIX cincy: <http://kg.513analytics.com/ont/cincy#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

# ============================================================================
# TEST 1: Core Classes Exist
# ============================================================================

# Test: Parcel class is defined
ASK WHERE {
  cincy:Parcel a owl:Class .
} ;

# Test: ParcelYearState class is defined
ASK WHERE {
  cincy:ParcelYearState a owl:Class .
} ;

# Test: Party class is defined
ASK WHERE {
  cincy:Party a owl:Class .
} ;

# Test: Person class is defined
ASK WHERE {
  cincy:Person a owl:Class .
} ;

# Test: Organization class is defined
ASK WHERE {
  cincy:Organization a owl:Class .
} ;

# Test: Assessment class is defined
ASK WHERE {
  cincy:Assessment a owl:Class .
} ;

# Test: TaxDistrict class is defined
ASK WHERE {
  cincy:TaxDistrict a owl:Class .
} ;

# Test: Exemption class is defined
ASK WHERE {
  cincy:Exemption a owl:Class .
} ;

# Test: Abatement class is defined
ASK WHERE {
  cincy:Abatement a owl:Class .
} ;

# Test: DelinquencyRecord class is defined
ASK WHERE {
  cincy:DelinquencyRecord a owl:Class .
} ;

# Test: CensusTract class is defined
ASK WHERE {
  cincy:CensusTract a owl:Class .
} ;

# Test: CensusBlock class is defined
ASK WHERE {
  cincy:CensusBlock a owl:Class .
} ;

# ============================================================================
# TEST 2: Class Hierarchy
# ============================================================================

# Test: Person is subclass of Party
ASK WHERE {
  cincy:Person rdfs:subClassOf cincy:Party .
} ;

# Test: Organization is subclass of Party
ASK WHERE {
  cincy:Organization rdfs:subClassOf cincy:Party .
} ;

# Test: LLC is subclass of Organization
ASK WHERE {
  cincy:LLC rdfs:subClassOf cincy:Organization .
} ;

# Test: Trust is subclass of Organization
ASK WHERE {
  cincy:Trust rdfs:subClassOf cincy:Organization .
} ;

# ============================================================================
# TEST 3: Land Use Vocabulary (SKOS)
# ============================================================================

# Test: LandUseScheme is defined
ASK WHERE {
  cincy:LandUseScheme a skos:ConceptScheme .
} ;

# Test: LandUseCode class is defined
ASK WHERE {
  cincy:LandUseCode a rdfs:Class .
} ;

# Test: Agricultural category exists
ASK WHERE {
  cincy:LU_Agricultural a cincy:LandUseCode ;
                         skos:notation "1xx" .
} ;

# Test: Residential category exists
ASK WHERE {
  cincy:LU_Residential a cincy:LandUseCode ;
                        skos:notation "5xx" .
} ;

# ============================================================================
# TEST 4: Ontology Metadata
# ============================================================================

# Test: Ontology IRI is defined
ASK WHERE {
  <http://kg.513analytics.com/ont/cincy> a owl:Ontology .
} ;

# Test: Ontology has version info
ASK WHERE {
  <http://kg.513analytics.com/ont/cincy> owl:versionInfo ?version .
} ;

# Test: Ontology imports GeoSPARQL
ASK WHERE {
  <http://kg.513analytics.com/ont/cincy> owl:imports <http://www.opengis.net/ont/geosparql> .
} ;

# Test: Ontology imports SKOS
ASK WHERE {
  <http://kg.513analytics.com/ont/cincy> owl:imports <http://www.w3.org/2004/02/skos/core> .
} ;

# ============================================================================
# TEST 5: Transfer, Mortgage, and Ownership Classes
# ============================================================================

# Test: TransferEvent class is defined
ASK WHERE {
  cincy:TransferEvent a owl:Class .
} ;

# Test: Mortgage class is defined
ASK WHERE {
  cincy:Mortgage a owl:Class .
} ;

# Test: OwnershipInterest class is defined
ASK WHERE {
  cincy:OwnershipInterest a owl:Class .
} ;

# ============================================================================
# TEST 6: Transfer Vocabulary (SKOS)
# ============================================================================

# Test: TransferClassificationScheme is defined
ASK WHERE {
  cincy:TransferClassificationScheme a skos:ConceptScheme .
} ;

# Test: TransferClassification class is defined
ASK WHERE {
  cincy:TransferClassification a rdfs:Class .
} ;

# Test: Arm's Length Sale concept exists
ASK WHERE {
  cincy:TC_ArmsLength a cincy:TransferClassification ;
                       skos:broader cincy:TC_MarketSale .
} ;

# Test: Judicial Foreclosure concept exists
ASK WHERE {
  cincy:TC_JudicialForeclosure a cincy:TransferClassification ;
                                skos:broader cincy:TC_CourtOrdered .
} ;

# ============================================================================
# TEST 7: Mortgage Type Vocabulary (SKOS)
# ============================================================================

# Test: MortgageTypeScheme is defined
ASK WHERE {
  cincy:MortgageTypeScheme a skos:ConceptScheme .
} ;

# Test: MortgageType class is defined
ASK WHERE {
  cincy:MortgageType a rdfs:Class .
} ;

# Test: FHA Loan concept exists
ASK WHERE {
  cincy:MT_FHA a cincy:MortgageType ;
               skos:broader cincy:MT_GovernmentBacked .
} ;

# Test: OHFA First-Time Homebuyer concept exists
ASK WHERE {
  cincy:MT_OHFAFirstTime a cincy:MortgageType ;
                          skos:broader cincy:MT_StateProgram .
} ;

# ============================================================================
# TEST 8: Payment Structure and Ownership Type Vocabularies
# ============================================================================

# Test: PaymentStructureScheme is defined
ASK WHERE {
  cincy:PaymentStructureScheme a skos:ConceptScheme .
} ;

# Test: Balloon payment structure exists
ASK WHERE {
  cincy:PS_Balloon a cincy:PaymentStructure ;
                    skos:topConceptOf cincy:PaymentStructureScheme .
} ;

# Test: OwnershipTypeScheme is defined
ASK WHERE {
  cincy:OwnershipTypeScheme a skos:ConceptScheme .
} ;

# Test: Survivorship Tenancy concept exists
ASK WHERE {
  cincy:OT_SurvivorshipTenancy a cincy:OwnershipType ;
                                skos:topConceptOf cincy:OwnershipTypeScheme .
} ;

# Test: Tenancy in Common concept exists
ASK WHERE {
  cincy:OT_TenancyInCommon a cincy:OwnershipType ;
                            skos:topConceptOf cincy:OwnershipTypeScheme .
} ;

# ============================================================================
# TEST 9: Heirs' Property (Tangled Title)
# ============================================================================

# Test: HeirsPropertyDesignation class is defined
ASK WHERE {
  cincy:HeirsPropertyDesignation a owl:Class .
} ;

# Test: Heirs' Property ownership type concept exists
ASK WHERE {
  cincy:OT_HeirsProperty a cincy:OwnershipType ;
                          skos:topConceptOf cincy:OwnershipTypeScheme .
} ;
