# =============================================================================
# TRANSFER TYPE SCHEME
# =============================================================================

cincy:TransferTypeScheme
    a skos:ConceptScheme ;
    skos:prefLabel "Transfer Type Codes"@en .

cincy:TransferType
    a rdfs:Class ;
    rdfs:subClassOf skos:Concept .

cincy:TT_ArmsLength a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "AL" ; skos:prefLabel "Arms-Length Sale"@en .

cincy:TT_ShortSale a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "SS" ; skos:prefLabel "Short Sale"@en .

cincy:TT_Foreclosure a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "FC" ; skos:prefLabel "Foreclosure Sale"@en .

cincy:TT_SheriffSale a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "SH" ; skos:prefLabel "Sheriff Sale"@en .

cincy:TT_QuitClaim a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "QC" ; skos:prefLabel "Quit Claim Deed"@en .

cincy:TT_TaxLien a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "TL" ; skos:prefLabel "Tax Lien Sale"@en .

cincy:TT_FamilyTransfer a cincy:TransferType ; skos:inScheme cincy:TransferTypeScheme ;
    skos:notation "FT" ; skos:prefLabel "Family Transfer"@en .
