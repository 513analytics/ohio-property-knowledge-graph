@prefix cincy:   <http://kg.513analytics.com/ont/cincy#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# =============================================================================
# CONCEPT SCHEME
# =============================================================================

cincy:LandUseScheme
    a skos:ConceptScheme ;
    rdfs:label "Hamilton County Land Use Codes"@en ;
    skos:prefLabel "Hamilton County Land Use Codes"@en ;
    dcterms:source "Ohio Administrative Code Rule 5703-25-10" ;
    skos:definition """Land use classification codes as published by the Hamilton
    County Auditor. The base coding system is defined by Ohio Administrative Code
    Rule 5703-25-10 (per ORC Section 5713.041), effective for tax year 1985. The
    first digit identifies the major use and the last two digits the sub-use.

    Eight top-level categories: Agricultural (100s), Mineral Lands & Rights
    (200s), Industrial (300s), Commercial (400s), Residential (500s), Exempt
    (600s), Special Tax Abatements (700s), Public Utilities (800s).

    Hamilton County extends the state code list with additional sub-codes
    (e.g., 351, 404-406, 413, 470-471, 489, 551-558, 625, 750, 760, 881, 999)
    for local classification needs. A parcel's land use code can change
    between tax years.

    Ohio law requires each parcel to be classified into one of two
    assessment classes (ORC 5713.041): (1) Residential and agricultural, or
    (2) All other (commercial, industrial, mineral, public utility). Improved
    parcels are classified by principal and current use; vacant parcels are
    classified by location and highest and best probable legal use.

    For residential codes (500s), the last digit encodes tract size:
    0 = platted lot, 1 = unplatted 0-9.99 acres, 2 = unplatted 10-19.99
    acres, 3 = unplatted 20-29.99 acres, 4 = unplatted 30-39.99 acres,
    5 = unplatted 40+ acres."""@en ;
    skos:historyNote "Base codes defined by OAC 5703-25-10 effective 1985. Hamilton County extensions added subsequently by the County Auditor."@en .

cincy:LandUseCode
    a rdfs:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Land Use Code"@en ;
    rdfs:comment """A 3-digit classification code for real property. The first digit
    identifies the major use category and the last two digits the sub-use. Codes
    are defined by Ohio Administrative Code Rule 5703-25-10 with local Hamilton
    County extensions."""@en .

# =============================================================================
# TOP-LEVEL CATEGORIES
# =============================================================================

cincy:LU_Agricultural
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Agricultural"@en ;
    skos:notation "1xx" ;
    skos:definition """The land and improvements to land used for agricultural
    purposes, including, but not limited to, general crop farming, dairying,
    animal and poultry husbandry, market and vegetable gardening, floriculture,
    nurseries, fruit and nut orchards, vineyards and forestry.
    (OAC 5703-25-10(B)(1))"""@en .

cincy:LU_MineralLands
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Mineral Lands & Rights"@en ;
    skos:altLabel "Extraction"@en ;
    skos:notation "2xx" ;
    skos:definition """Land, and the buildings and improvements thereon, used for
    mining coal and other minerals as well as the production of oil and gas
    including the rights to mine and produce such minerals whether separated
    from the fee or not. (OAC 5703-25-10(B)(2))"""@en .

cincy:LU_Industrial
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Industrial"@en ;
    skos:notation "3xx" ;
    skos:definition """The land and improvements to land used for manufacturing,
    processing, or refining foods and materials, and warehouses used in
    connection therewith. (OAC 5703-25-10(B)(3))"""@en .

cincy:LU_Commercial
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Commercial"@en ;
    skos:notation "4xx" ;
    skos:definition """The land and improvements to land which are owned or occupied
    for general commercial and income producing purposes and where production of
    income is a factor to be considered in arriving at true value, including, but
    not limited to, apartment houses, hotels, motels, theaters, office buildings,
    warehouses, retail and wholesale stores, bank buildings, commercial garages,
    commercial parking lots, and shopping centers.
    (OAC 5703-25-10(B)(4))"""@en .

cincy:LU_Residential
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Residential"@en ;
    skos:notation "5xx" ;
    skos:definition """The land and improvements to the land used and occupied by one,
    two, or three families. (OAC 5703-25-10(B)(5)) For residential codes, the
    third digit indicates the size of tract: 0 = platted lot, 1 = unplatted
    0-9.99 acres, 2 = unplatted 10-19.99 acres, 3 = unplatted 20-29.99 acres,
    4 = unplatted 30-39.99 acres, 5 = unplatted 40+ acres."""@en .

cincy:LU_PubliclyOwned
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Publicly Owned"@en ;
    skos:notation "6xx" .

cincy:LU_Abated
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Abated"@en ;
    skos:notation "7xx" ;
    skos:definition """Abatement codes exist in parallel with land use codes. A parcel
    retains its underlying use classification (e.g., Residential 510) and is
    additionally assigned a 700s code to indicate the type of abatement."""@en .

cincy:LU_PublicUtilities
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Public Utilities"@en ;
    skos:notation "8xx" .

