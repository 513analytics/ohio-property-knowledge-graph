@prefix cincy:   <http://kg.513analytics.com/ont/cincy#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# CONCEPT SCHEME
# =============================================================================

cincy:LandUseScheme
    a skos:ConceptScheme ;
    rdfs:label "Hamilton County Land Use Codes"@en ;
    skos:prefLabel "Hamilton County Land Use Codes"@en ;
    skos:definition """Land use classification codes as published by the Hamilton
    County Auditor, aligned with Ohio Department of Tax Equalization (DTE) codes.
    Eight top-level categories: Agricultural (100s), Extraction (200s), Industrial
    (300s), Commercial (400s), Residential (500s), Publicly Owned (600s), Abated
    (700s), Public Utilities (800s). A parcel's land use code can change between
    tax years."""@en .

cincy:LandUseCode
    a rdfs:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Land Use Code"@en .

# =============================================================================
# TOP-LEVEL CATEGORIES
# =============================================================================

cincy:LU_Agricultural
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Agricultural"@en ;
    skos:notation "1xx" .

cincy:LU_Extraction
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Extraction"@en ;
    skos:notation "2xx" .

cincy:LU_Industrial
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Industrial"@en ;
    skos:notation "3xx" .

cincy:LU_Commercial
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Commercial"@en ;
    skos:notation "4xx" .

cincy:LU_Residential
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Residential"@en ;
    skos:notation "5xx" .

cincy:LU_PubliclyOwned
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Publicly Owned"@en ;
    skos:notation "6xx" .

cincy:LU_Abated
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Abated"@en ;
    skos:notation "7xx" ;
    skos:definition """Abatement codes exist in parallel with land use codes. A parcel
    retains its underlying use classification (e.g., Residential 510) and is
    additionally assigned a 700s code to indicate the type of abatement."""@en .

cincy:LU_PublicUtilities
    a cincy:LandUseCode ;
    skos:inScheme cincy:LandUseScheme ;
    skos:topConceptOf cincy:LandUseScheme ;
    skos:prefLabel "Public Utilities"@en ;
    skos:notation "8xx" .

