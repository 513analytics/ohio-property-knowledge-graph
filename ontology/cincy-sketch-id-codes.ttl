@prefix cincy:   <http://kg.513analytics.com/ont/cincy#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# CONCEPT SCHEME
# =============================================================================

cincy:SketchIdScheme
    a skos:ConceptScheme ;
    rdfs:label "Hamilton County Sketch ID Codes"@en ;
    skos:prefLabel "Hamilton County Sketch ID Codes"@en ;
    skos:definition """Sketch identification codes as published by the Hamilton County
    Auditor. Used in property sketch drawings to identify attached additions (wall
    codes), detached additions, and story height configurations for parcels. Three
    categories: Detached Additions (numeric codes 01–199), Attached Additions /
    Wall Codes (alphanumeric, e.g. GR1, PR2), and Story Heights (e.g. 1s, A4)."""@en .

cincy:SketchIdCode
    a rdfs:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Sketch ID Code"@en .

# =============================================================================
# TOP-LEVEL CATEGORIES
# =============================================================================

cincy:SK_DetachedAdditions
    a cincy:SketchIdCode ;
    skos:inScheme cincy:SketchIdScheme ;
    skos:topConceptOf cincy:SketchIdScheme ;
    skos:prefLabel "Detached Additions"@en ;
    skos:notation "01-199" ;
    skos:definition "Structures not physically connected to the main building, identified by numeric codes."@en .

cincy:SK_AttachedAdditions
    a cincy:SketchIdCode ;
    skos:inScheme cincy:SketchIdScheme ;
    skos:topConceptOf cincy:SketchIdScheme ;
    skos:prefLabel "Attached Additions"@en ;
    skos:notation "Wall Codes" ;
    skos:definition "Structures physically connected (attached) to the main building, identified by alphanumeric wall codes."@en .

cincy:SK_StoryHeights
    a cincy:SketchIdCode ;
    skos:inScheme cincy:SketchIdScheme ;
    skos:topConceptOf cincy:SketchIdScheme ;
    skos:prefLabel "Story Heights"@en ;
    skos:definition "Vertical configuration codes describing the number of stories and attic finish level of a structure."@en .

