@prefix cincy:   <http://kg.513analytics.com/ont/cincy#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix schema:  <https://schema.org/> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ladm:    <http://www.iso.org/19152/ladm#> .

# =============================================================================
# ONTOLOGY DECLARATION
# =============================================================================

<http://kg.513analytics.com/ont/cincy>
    a owl:Ontology ;
    rdfs:label "cincinnati Housing Knowledge Graph Ontology"@en ;
    dcterms:description """Ontology for modeling Hamilton County, Ohio real property
    data as maintained by the County Auditor. Covers parcels, ownership, valuation,
    taxation, land use classification, abatements, TIF districts, and rental
    registration. Aligned with ISO 19152 LADM, OGC GeoSPARQL 1.1, W3C SKOS,
    W3C OWL-Time, schema.org, and QUDT."""@en ;
    dcterms:creator "513 Analytics" ;
    dcterms:created "2026-04-05"^^xsd:date ;
    owl:versionInfo "0.3.0" ;
    owl:imports <http://www.opengis.net/ont/geosparql> ,
                <http://www.w3.org/2004/02/skos/core> ,
                <http://www.w3.org/2006/time> .

# =============================================================================
# CLASSES
# =============================================================================

# ---------------------------------------------------------------------------
# 1. PARCEL — the central cadastral entity
# ---------------------------------------------------------------------------

cincy:Parcel
    a owl:Class ;
    rdfs:subClassOf geo:Feature , ladm:LA_SpatialUnit ;
    rdfs:label "Parcel"@en ;
    rdfs:comment """A legally defined unit of land in Hamilton County, identified by
    a composite key: book + page + parcel-ID-on-page + mltown = auditor parcel
    number. The parcel is the Auditor's fundamental unit of real property."""@en .

# ---------------------------------------------------------------------------
# 2. PARCEL YEAR STATE — time-varying attributes that change each tax year
# ---------------------------------------------------------------------------

cincy:ParcelYearState
    a owl:Class ;
    rdfs:label "Parcel Year State"@en ;
    rdfs:comment """A snapshot of a parcel's mutable attributes for a single tax
    year. Land use code, owner-occupied status, homestead exemption, rental
    registration, new-construction flag, recently-divided flag, and board-of-
    revision dispute status can all change between tax years. Each ParcelYearState
    links to exactly one Parcel and one tax year."""@en .

# ---------------------------------------------------------------------------
# 3. PARTIES — owners, mortgage servicers, rental contacts
# ---------------------------------------------------------------------------

cincy:Party
    a owl:Class ;
    rdfs:subClassOf ladm:LA_Party ;
    rdfs:label "Party"@en ;
    rdfs:comment "Abstract. A person or organization involved in property ownership or administration."@en .

cincy:Person
    a owl:Class ;
    rdfs:subClassOf cincy:Party , schema:Person ;
    rdfs:label "Person"@en .

cincy:Organization
    a owl:Class ;
    rdfs:subClassOf cincy:Party , schema:Organization ;
    rdfs:label "Organization"@en .

cincy:LLC
    a owl:Class ;
    rdfs:subClassOf cincy:Organization ;
    rdfs:label "Limited Liability Company"@en .

cincy:Trust
    a owl:Class ;
    rdfs:subClassOf cincy:Organization ;
    rdfs:label "Trust"@en .

cincy:GovernmentEntity
    a owl:Class ;
    rdfs:subClassOf cincy:Organization ;
    rdfs:label "Government Entity"@en .

cincy:NonProfit
    a owl:Class ;
    rdfs:subClassOf cincy:Organization ;
    rdfs:label "Non-Profit Organization"@en .

cincy:MortgageServicer
    a owl:Class ;
    rdfs:subClassOf cincy:Organization ;
    rdfs:label "Mortgage Servicer"@en ;
    rdfs:comment "Mortgage provider or designee who receives tax bills on behalf of the owner."@en .

# ---------------------------------------------------------------------------
# 4. VALUATION & ASSESSMENT
# ---------------------------------------------------------------------------

cincy:Assessment
    a owl:Class ;
    rdfs:label "Assessment"@en ;
    rdfs:comment """A time-bound valuation record for a parcel. Ohio reappraises on
    a 6-year cycle with triennial updates. Produces three value components: land,
    improvements (structures), and agricultural use (CAUV). The total assessed
    value is the sum. Taxable value is the total minus any exemption, abatement,
    or TIF reduction amounts."""@en .

# ---------------------------------------------------------------------------
# 5. APPRAISAL AREAS & NEIGHBORHOODS
# ---------------------------------------------------------------------------

cincy:Neighborhood
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Neighborhood"@en ;
    rdfs:comment """A named geographic area within Hamilton County used as a
    high-level grouping for appraisal areas. Within the City of Cincinnati,
    neighborhood boundaries align with recognized community council areas."""@en .

cincy:AppraisalArea
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Appraisal Area"@en ;
    rdfs:comment """A sub-area within a neighborhood used by the Hamilton County
    Auditor for mass appraisal comparisons. Assessors group comparable parcels
    within an appraisal area to establish market values on the Ohio 6-year
    reappraisal cycle. Identified by a 5-digit code."""@en .

# ---------------------------------------------------------------------------
# 6. TAXATION
# ---------------------------------------------------------------------------

cincy:TaxDistrict
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Tax District"@en ;
    rdfs:comment """A geographic area that determines which levies apply to parcels
    within it. Each parcel is in exactly one tax district. Tax districts are
    composites of overlapping jurisdictions (city, county, school, library,
    park, etc.). Identified by a 3-digit code."""@en .

cincy:SchoolDistrict
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "School District"@en ;
    rdfs:comment """School districts are tracked separately because they are the
    largest recipients of property tax revenue. Identified by a 5-digit IRN
    (Institution Revenue Number) code."""@en .

cincy:Levy
    a owl:Class ;
    rdfs:label "Levy"@en ;
    rdfs:comment "An individual tax levy (voted or unvoted) within a tax district. Tax is assessed against millage."@en .

cincy:TaxBill
    a owl:Class ;
    rdfs:label "Tax Bill"@en ;
    rdfs:comment "The computed tax obligation for a parcel in a given tax year."@en .

# ---------------------------------------------------------------------------
# 6. TAX INCENTIVE / EXEMPT STRUCTURES
# ---------------------------------------------------------------------------

cincy:TIFDistrict
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "TIF District"@en ;
    rdfs:comment """Tax Increment Financing district. Revenue above a base-year
    assessed value is diverted to fund infrastructure improvements."""@en .

cincy:TaxReduction
    a owl:Class ;
    rdfs:label "Tax Reduction"@en ;
    rdfs:comment """A reduction in the taxable value of a parcel. Covers abatements
    (CRA, enterprise zone, etc.), TIF diversions, and full exemptions for
    publicly owned or non-profit properties. The reduction is an integer dollar
    amount subtracted from the total assessed value — not a percentage."""@en .

cincy:Abatement
    a owl:Class ;
    rdfs:subClassOf cincy:TaxReduction ;
    rdfs:label "Abatement"@en ;
    rdfs:comment """A time-limited reduction of taxable value for new construction or
    renovation. Classified in the 700s land use codes. The abatement amount is
    an integer dollar value less than or equal to the total assessed value."""@en .

cincy:TIFReduction
    a owl:Class ;
    rdfs:subClassOf cincy:TaxReduction ;
    rdfs:label "TIF Reduction"@en ;
    rdfs:comment "The dollar amount of assessed value diverted to a TIF district."@en .

cincy:Exemption
    a owl:Class ;
    rdfs:subClassOf cincy:TaxReduction ;
    rdfs:label "Exemption"@en ;
    rdfs:comment """Full or partial exemption from property tax. Publicly owned (600s)
    and non-profit owned properties are typically fully exempt. The exemption
    amount is an integer dollar value."""@en .

# ---------------------------------------------------------------------------
# 7. TRANSFER EVENTS
# ---------------------------------------------------------------------------

cincy:TransferEvent
    a owl:Class ;
    rdfs:label "Transfer Event"@en ;
    rdfs:comment """Records an ownership change for a parcel. Captures sale price,
    deed type, instrument number, conveyance fee, and transfer classification.
    Ohio requires filing DTE Form 100 with the county auditor for all transfers.
    The Ohio conveyance fee (ORC 319.54) is $1.00 per $1,000 of consideration
    at the state level plus up to $3.00 per $1,000 as a county permissive fee;
    Hamilton County levies the full permissive fee for a combined rate of $4.00
    per $1,000. Certain transfers are exempt per ORC 319.54(G)."""@en .

# ---------------------------------------------------------------------------
# 7a. MORTGAGE — lien securing a debt obligation
# ---------------------------------------------------------------------------

cincy:Mortgage
    a owl:Class ;
    rdfs:label "Mortgage"@en ;
    rdfs:comment """A recorded lien on a parcel securing a debt obligation. Ohio is
    a lien theory state: the borrower retains legal title while the lender holds
    a security interest (ORC Chapter 5301). Mortgages must be recorded with the
    county recorder to establish constructive notice and lien priority under
    Ohio's race-notice recording statute (ORC 5301.25). Lenders must provide a
    certificate of satisfaction within 90 days of payoff (ORC 5301.36). Ohio
    also recognizes open-end mortgages (ORC 5301.232), which secure future
    advances up to a stated maximum without re-recording."""@en .

# ---------------------------------------------------------------------------
# 7b. OWNERSHIP INTEREST — how parties hold title
# ---------------------------------------------------------------------------

cincy:OwnershipInterest
    a owl:Class ;
    rdfs:label "Ownership Interest"@en ;
    rdfs:comment """Records how one or more parties hold title to a parcel. Ohio
    recognizes several forms of concurrent ownership: survivorship tenancy
    (ORC 5302.20), tenancy in common (the default when survivorship language
    is absent), and life estate with remainder. Ohio does NOT recognize tenancy
    by the entireties or community property. Trust ownership and Transfer on
    Death (TOD) designation affidavits (ORC 5302.22) are also modeled. Each
    OwnershipInterest links a party to a parcel with a specific ownership type
    and optional fractional share."""@en .

# ---------------------------------------------------------------------------
# 7c. HEIRS' PROPERTY — tangled title from uncleared estates
# ---------------------------------------------------------------------------

cincy:HeirsPropertyDesignation
    a owl:Class ;
    rdfs:label "Heirs' Property Designation"@en ;
    rdfs:comment """A designation that a parcel is heirs' property (also called
    'tangled title'). This occurs when the owner of record is deceased and
    the surviving heirs continue to occupy or hold the property without
    clearing title through probate court. Under Ohio intestate succession
    law (ORC 2105.06), the heirs hold undivided fractional interests as
    tenants in common by operation of law, but without a recorded deed the
    title remains clouded and unmarketable. The owner of record in the
    Auditor's system remains the decedent. Heirs' property is a significant
    barrier to housing stability: heirs cannot obtain traditional mortgages,
    secure homeowner's insurance at standard rates, qualify for FEMA
    disaster assistance, or participate in home repair programs. The problem
    compounds across generations as the number of potential heirs multiplies.
    In Hamilton County this disproportionately affects lower-income
    neighborhoods with older housing stock. Resolution requires a probate
    proceeding, an heirship affidavit, or a quiet title action. Ohio
    adopted the Uniform Partition of Heirs Property Act (ORC 5307.20 et
    seq.) effective April 6, 2023, which provides protections against
    forced partition sales that can displace heirs."""@en .

# ---------------------------------------------------------------------------
# 8. RENTAL REGISTRATION
# ---------------------------------------------------------------------------

cincy:RentalRegistration
    a owl:Class ;
    rdfs:label "Rental Registration"@en ;
    rdfs:comment """A registration record for a rental property as required by the
    Hamilton County Auditor. Includes the contact person name extracted via OCR
    from the registration PDF."""@en .

# ---------------------------------------------------------------------------
# 9. BOARD OF REVISION DISPUTE
# ---------------------------------------------------------------------------


cincy:BoardOfRevisionDispute
    a owl:Class ;
    rdfs:label "Board of Revision Dispute"@en ;
    rdfs:comment """A record that the owner disputed an assessment before the Board
    of Revision. The disputed value details are trapped in PDF documents and not
    currently available; only the year(s) of dispute are captured."""@en .

# ---------------------------------------------------------------------------
# 10. TAX DELINQUENCY
# ---------------------------------------------------------------------------

cincy:DelinquencyRecord
    a owl:Class ;
    rdfs:label "Delinquency Record"@en ;
    rdfs:comment """A formal designation that a parcel carries an unpaid tax balance
    that survived end-of-year Treasurer reconciliation and was added to the
    Hamilton County delinquent land list. Distinct from merely having an unpaid
    installment: a parcel must carry the balance through the annual reconciliation
    to become delinquent. Delinquent parcels are subject to county or third-party
    collector foreclosure if the balance remains unpaid the following year. The
    Auditor records the current delinquent balance and whether the owner has
    entered a formal repayment contract."""@en .

# ---------------------------------------------------------------------------
# 11. CENSUS GEOGRAPHY
# ---------------------------------------------------------------------------

cincy:CensusTract
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Census Tract"@en ;
    rdfs:comment """A U.S. Census Bureau statistical subdivision of a county,
    designed to contain roughly 1,200–8,000 people with relatively homogeneous
    population characteristics. Identified by an 11-digit GEOID (2-digit state
    FIPS + 3-digit county FIPS + 6-digit tract code). Hamilton County census
    tracts are the standard unit for neighborhood-level analysis."""@en .

cincy:CensusBlock
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Census Block"@en ;
    rdfs:comment """The smallest U.S. Census Bureau geographic unit, typically
    bounded by streets, waterways, or other visible features. Identified by a
    15-digit GEOID (2-digit state FIPS + 3-digit county FIPS + 6-digit tract
    code + 4-digit block number). Every parcel can be assigned to exactly one
    census block."""@en .

# =============================================================================
# OBJECT PROPERTIES
# =============================================================================

# --- Parcel → Party ---

cincy:ownedBy
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Party ;
    rdfs:label "owned by"@en ;
    rdfs:comment """The auditor tracks the parcel owner only. If land is leased and
    a structure is owned by a different party, the auditor records the landowner.
    This relationship is temporal — use time:hasBeginning / time:hasEnd or
    the ParcelYearState to track ownership periods."""@en ;
    owl:inverseOf cincy:owns .

cincy:owns
    a owl:ObjectProperty ;
    rdfs:domain cincy:Party ;
    rdfs:range cincy:Parcel ;
    rdfs:label "owns"@en ;
    owl:inverseOf cincy:ownedBy .

# --- Parcel → year state ---

cincy:hasYearState
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:ParcelYearState ;
    rdfs:label "has year state"@en .

# --- ParcelYearState → classification ---

cincy:hasLandUse
    a owl:ObjectProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range cincy:LandUseCode ;
    rdfs:label "has land use"@en ;
    rdfs:comment "The Ohio DTE / Hamilton County land use code for this parcel in this tax year."@en .

# --- Tax bill routing ---

cincy:taxBillRecipient
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Party ;
    rdfs:label "tax bill recipient"@en ;
    rdfs:comment "Who receives the tax bill. Often a mortgage servicer rather than the owner."@en .

# --- Parcel → geographic districts ---

cincy:inTaxDistrict
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:TaxDistrict ;
    rdfs:label "in tax district"@en .

cincy:inSchoolDistrict
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:SchoolDistrict ;
    rdfs:label "in school district"@en .

cincy:servesSchoolDistrict
    a owl:ObjectProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range cincy:SchoolDistrict ;
    rdfs:label "serves school district"@en ;
    rdfs:comment "The school district that receives tax revenue from parcels within this tax district."@en .

cincy:inAppraisalArea
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:AppraisalArea ;
    rdfs:label "in appraisal area"@en ;
    rdfs:comment "The appraisal area assigned to this parcel by the Hamilton County Auditor for mass appraisal comparisons."@en .

cincy:inNeighborhood
    a owl:ObjectProperty ;
    rdfs:domain cincy:AppraisalArea ;
    rdfs:range cincy:Neighborhood ;
    rdfs:label "in neighborhood"@en .

cincy:neighborhoodOf
    a owl:ObjectProperty ;
    rdfs:domain cincy:Neighborhood ;
    rdfs:range cincy:AppraisalArea ;
    rdfs:label "neighborhood of"@en ;
    owl:inverseOf cincy:inNeighborhood .

cincy:inTIFDistrict
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:TIFDistrict ;
    rdfs:label "in TIF district"@en .

# --- Assessment ---

cincy:hasAssessment
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Assessment ;
    rdfs:label "has assessment"@en .

# --- Tax reductions ---

cincy:hasTaxReduction
    a owl:ObjectProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range cincy:TaxReduction ;
    rdfs:label "has tax reduction"@en ;
    rdfs:comment "Links a parcel's year state to any abatement, TIF reduction, or exemption. Multiple may apply."@en .

# --- Transfers ---

cincy:hasTransfer
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:TransferEvent ;
    rdfs:label "has transfer"@en .

cincy:fromParty
    a owl:ObjectProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range cincy:Party ;
    rdfs:label "from party (seller/grantor)"@en .

cincy:toParty
    a owl:ObjectProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range cincy:Party ;
    rdfs:label "to party (buyer/grantee)"@en .

cincy:transferType
    a owl:ObjectProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range cincy:TransferClassification ;
    rdfs:label "transfer type"@en ;
    rdfs:comment """Classifies the nature of the transfer (arm's length sale,
    foreclosure, gift, etc.). Orthogonal to deed type — a warranty deed can
    be used for an arm's length sale or a gift."""@en .

cincy:financedBy
    a owl:ObjectProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range cincy:Mortgage ;
    rdfs:label "financed by"@en ;
    rdfs:comment "Links a transfer event to the mortgage used to finance the purchase, if any."@en .

# --- Mortgage ---

cincy:hasMortgage
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Mortgage ;
    rdfs:label "has mortgage"@en ;
    rdfs:comment "Links a parcel to a mortgage lien recorded against it."@en .

cincy:mortgagor
    a owl:ObjectProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range cincy:Party ;
    rdfs:label "mortgagor (borrower)"@en ;
    rdfs:comment "The borrower — the party who pledges the property as security."@en .

cincy:mortgagee
    a owl:ObjectProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range cincy:Party ;
    rdfs:label "mortgagee (lender)"@en ;
    rdfs:comment "The lender — the party who holds the lien on the property."@en .

cincy:mortgageType
    a owl:ObjectProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range cincy:MortgageType ;
    rdfs:label "mortgage type"@en ;
    rdfs:comment "Classification of the mortgage (conventional, FHA, VA, OHFA, etc.)."@en .

cincy:paymentStructure
    a owl:ObjectProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range cincy:PaymentStructure ;
    rdfs:label "payment structure"@en ;
    rdfs:comment "How the mortgage is repaid (fully amortizing, balloon, interest-only, etc.)."@en .

# --- Ownership Interest ---

cincy:hasOwnershipInterest
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:OwnershipInterest ;
    rdfs:label "has ownership interest"@en ;
    rdfs:comment """Links a parcel to the ownership interest records that describe
    how title is held. A parcel may have multiple concurrent interests (e.g.,
    two parties as survivorship tenants, or a life tenant and remainderman)."""@en .

cincy:interestHolder
    a owl:ObjectProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range cincy:Party ;
    rdfs:label "interest holder"@en ;
    rdfs:comment "The party who holds this ownership interest."@en .

cincy:ownershipType
    a owl:ObjectProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range cincy:OwnershipType ;
    rdfs:label "ownership type"@en ;
    rdfs:comment "The form of ownership (survivorship tenancy, tenancy in common, life estate, etc.)."@en .

cincy:remainderHolder
    a owl:ObjectProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range cincy:Party ;
    rdfs:label "remainder holder"@en ;
    rdfs:comment """For life estates: the party who receives the property upon the
    death of the life tenant."""@en .

# --- Heirs' Property ---

cincy:hasHeirsPropertyDesignation
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:HeirsPropertyDesignation ;
    rdfs:label "has heirs' property designation"@en ;
    rdfs:comment """Links a parcel to its heirs' property (tangled title)
    designation. Indicates the owner of record is deceased and title has
    not been cleared through probate."""@en .

cincy:decedentOwner
    a owl:ObjectProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range cincy:Party ;
    rdfs:label "decedent owner"@en ;
    rdfs:comment "The deceased party who remains the owner of record."@en .

# --- Spatial ---

cincy:adjacentTo
    a owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Parcel ;
    rdfs:label "adjacent to"@en ;
    rdfs:comment "Computed from geo:sfTouches on parcel geometries."@en .

cincy:subdividedFrom
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:Parcel ;
    rdfs:label "subdivided from"@en ;
    rdfs:comment "Tracks parcel lineage when a parcel is divided."@en .

# --- Rental registration ---

cincy:hasRentalRegistration
    a owl:ObjectProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range cincy:RentalRegistration ;
    rdfs:label "has rental registration"@en .

# --- BoR dispute ---

cincy:hasBoRDispute
    a owl:ObjectProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range cincy:BoardOfRevisionDispute ;
    rdfs:label "has Board of Revision dispute"@en .

# --- Census geography ---

cincy:inCensusTract
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:CensusTract ;
    rdfs:label "in census tract"@en .

cincy:inCensusBlock
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:CensusBlock ;
    rdfs:label "in census block"@en .

cincy:tractContainsBlock
    a owl:ObjectProperty ;
    rdfs:domain cincy:CensusTract ;
    rdfs:range cincy:CensusBlock ;
    rdfs:label "tract contains block"@en ;
    owl:inverseOf cincy:blockInTract .

cincy:blockInTract
    a owl:ObjectProperty ;
    rdfs:domain cincy:CensusBlock ;
    rdfs:range cincy:CensusTract ;
    rdfs:label "block in tract"@en ;
    owl:inverseOf cincy:tractContainsBlock .

# --- Tax delinquency ---

cincy:hasDelinquencyRecord
    a owl:ObjectProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range cincy:DelinquencyRecord ;
    rdfs:label "has delinquency record"@en ;
    rdfs:comment """Links a parcel to its formal delinquency record on the Hamilton
    County delinquent land list. A parcel may have at most one active record at
    a time; the record persists until the delinquent balance is paid in full."""@en .

# --- Levy → Tax District ---

cincy:hasLevy
    a owl:ObjectProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range cincy:Levy ;
    rdfs:label "has levy"@en .

# =============================================================================
# DATA PROPERTIES
# =============================================================================

# --- Parcel identification (immutable) ---

cincy:parcelNumber
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range xsd:string ;
    rdfs:label "parcel number"@en ;
    rdfs:comment "Composite auditor ID: book + page + parcel-on-page + mltown."@en .

cincy:book
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range xsd:string ;
    rdfs:label "plat book"@en .

cincy:page
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range xsd:string ;
    rdfs:label "plat page"@en .

cincy:parcelIdOnPage
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range xsd:string ;
    rdfs:label "parcel ID on page"@en .

cincy:mltown
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Parcel ;
    rdfs:range xsd:string ;
    rdfs:label "mltown code"@en ;
    rdfs:comment "Municipality/township code digits."@en .

# --- Party ---

cincy:ownerAddress
    a owl:ObjectProperty ;
    rdfs:domain cincy:Party ;
    rdfs:range schema:PostalAddress ;
    rdfs:label "owner address"@en .

cincy:mailingAddress
    a owl:ObjectProperty ;
    rdfs:domain cincy:Party ;
    rdfs:range schema:PostalAddress ;
    rdfs:label "mailing address"@en ;
    rdfs:comment "Where the tax bill is sent."@en .

# --- ParcelYearState flags ---

cincy:taxYear
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:gYear ;
    rdfs:label "tax year"@en .

cincy:isOwnerOccupied
    a owl:DatatypeProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:boolean ;
    rdfs:label "owner occupied (2.5% eligible)"@en ;
    rdfs:comment """Flag for owner-occupied status. Also known as '2_5' in the data.
    Eligible for 2.5% tax rollback reimbursed by the State of Ohio."""@en .

cincy:hasHomesteadExemption
    a owl:DatatypeProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:boolean ;
    rdfs:label "homestead exemption"@en ;
    rdfs:comment "State reimburses taxes on the first $75,000 of assessed value."@en .

cincy:isRentalRegistered
    a owl:DatatypeProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:boolean ;
    rdfs:label "rental registered"@en .

cincy:isNewConstruction
    a owl:DatatypeProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:boolean ;
    rdfs:label "new construction"@en .

cincy:wasRecentlyDivided
    a owl:DatatypeProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range xsd:boolean ;
    rdfs:label "recently divided"@en .

# --- Assessment values ---

cincy:assessedLandValue
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Assessment ;
    rdfs:range xsd:integer ;
    rdfs:label "assessed land value (USD)"@en .

cincy:assessedImprovementValue
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Assessment ;
    rdfs:range xsd:integer ;
    rdfs:label "assessed improvement value (USD)"@en ;
    rdfs:comment "Value of structures on the parcel."@en .

cincy:assessedAgValue
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Assessment ;
    rdfs:range xsd:integer ;
    rdfs:label "assessed agricultural (CAUV) value (USD)"@en .

cincy:totalAssessedValue
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Assessment ;
    rdfs:range xsd:integer ;
    rdfs:label "total assessed value (USD)"@en .

cincy:assessmentYear
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Assessment ;
    rdfs:range xsd:gYear ;
    rdfs:label "assessment year"@en .

# --- Tax reduction (abatement / TIF / exemption) ---

cincy:reductionAmount
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxReduction ;
    rdfs:range xsd:integer ;
    rdfs:label "reduction amount (USD)"@en ;
    rdfs:comment """An integer dollar amount subtracted from total assessed value.
    Must be less than or equal to the total assessed value."""@en .

cincy:reductionType
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxReduction ;
    rdfs:range xsd:string ;
    rdfs:label "reduction type"@en ;
    rdfs:comment "e.g., CRA (710), Enterprise Zone (750), Exempt (600s), TIF."@en .

cincy:reductionStartDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxReduction ;
    rdfs:range xsd:date ;
    rdfs:label "reduction start date"@en .

cincy:reductionEndDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxReduction ;
    rdfs:range xsd:date ;
    rdfs:label "reduction end date"@en .

# --- Levy / millage ---

cincy:millageRate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Levy ;
    rdfs:range xsd:decimal ;
    rdfs:label "millage rate"@en ;
    rdfs:comment "Rate in mills. 1 mill = $1 per $1,000 of taxable value."@en .

cincy:effectiveRate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Levy ;
    rdfs:range xsd:decimal ;
    rdfs:label "effective rate"@en ;
    rdfs:comment "Effective rate after HB 920 reduction factors."@en .

cincy:levyType
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Levy ;
    rdfs:range xsd:string ;
    rdfs:label "levy type"@en .

# --- Tax bill ---

cincy:grossTax
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxBill ;
    rdfs:range xsd:integer ;
    rdfs:label "gross tax (USD)"@en .

cincy:ownerOccupancyCredit
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxBill ;
    rdfs:range xsd:integer ;
    rdfs:label "owner occupancy credit (USD)"@en ;
    rdfs:comment "2.5% rollback reimbursed by the State of Ohio."@en .

cincy:homesteadReduction
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxBill ;
    rdfs:range xsd:integer ;
    rdfs:label "homestead reduction (USD)"@en .

cincy:netTax
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxBill ;
    rdfs:range xsd:integer ;
    rdfs:label "net tax (USD)"@en .

# --- Transfer event ---

cincy:salePrice
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:integer ;
    rdfs:label "sale price (USD)"@en .

cincy:transferDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:date ;
    rdfs:label "transfer date"@en .

cincy:instrumentNumber
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:string ;
    rdfs:label "instrument number"@en .

cincy:deedType
    a owl:ObjectProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range cincy:DeedType ;
    rdfs:label "deed type"@en ;
    rdfs:comment "Links a transfer event to its deed type classification (see cincy-deed-types.ttl)."@en .

cincy:conveyanceFee
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:decimal ;
    rdfs:label "conveyance fee (USD)"@en ;
    rdfs:comment """The Ohio real estate transfer tax paid on this conveyance.
    Calculated at $4.00 per $1,000 of consideration in Hamilton County
    ($1.00 state + $3.00 county permissive fee per ORC 319.54)."""@en .

cincy:isConveyanceFeeExempt
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:boolean ;
    rdfs:label "conveyance fee exempt"@en ;
    rdfs:comment """True if the transfer is exempt from the Ohio conveyance fee
    under ORC 319.54(G). Common exemptions include transfers between spouses,
    parent-child transfers, court-ordered transfers, government transfers,
    and transfers with consideration under $100."""@en .

cincy:isArmsLength
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:boolean ;
    rdfs:label "arm's length transaction"@en ;
    rdfs:comment """True if the transfer is between unrelated parties at fair
    market value. Non-arm's-length transactions (gifts, family transfers,
    corporate restructurings) are excluded from sales ratio studies."""@en .

cincy:dteFormNumber
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TransferEvent ;
    rdfs:range xsd:string ;
    rdfs:label "DTE form number"@en ;
    rdfs:comment """Ohio DTE Form 100 (Statement of Conveyance of Homestead
    Property) or Form 100EX (Exempt) filed with the county auditor for
    this transfer."""@en .

# --- Mortgage ---

cincy:mortgageAmount
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:integer ;
    rdfs:label "mortgage amount (USD)"@en ;
    rdfs:comment "The original principal amount of the mortgage loan."@en .

cincy:mortgageDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:date ;
    rdfs:label "mortgage date"@en ;
    rdfs:comment "The date the mortgage was executed."@en .

cincy:mortgageRecordingDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:date ;
    rdfs:label "mortgage recording date"@en ;
    rdfs:comment "The date the mortgage was recorded with the county recorder. Determines lien priority under Ohio's race-notice statute."@en .

cincy:mortgageInstrumentNumber
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:string ;
    rdfs:label "mortgage instrument number"@en ;
    rdfs:comment "The county recorder's instrument number for the recorded mortgage."@en .

cincy:interestRate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:decimal ;
    rdfs:label "interest rate"@en ;
    rdfs:comment "The annual interest rate as a percentage (e.g., 6.5 for 6.5%). For adjustable-rate mortgages, this is the initial rate."@en .

cincy:termMonths
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:integer ;
    rdfs:label "term in months"@en ;
    rdfs:comment "The loan term in months (e.g., 360 for a 30-year mortgage)."@en .

cincy:isOpenEnd
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:boolean ;
    rdfs:label "open-end mortgage"@en ;
    rdfs:comment """True if this is an open-end mortgage under ORC 5301.232,
    which allows additional advances up to a stated maximum without
    re-recording. Priority relates back to the original recording date."""@en .

cincy:maxOpenEndAmount
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:integer ;
    rdfs:label "maximum open-end amount (USD)"@en ;
    rdfs:comment "For open-end mortgages: the maximum principal secured."@en .

cincy:isSatisfied
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:boolean ;
    rdfs:label "is satisfied"@en ;
    rdfs:comment """True if the mortgage has been fully paid and a certificate
    of satisfaction recorded. Ohio requires lenders to record satisfaction
    within 90 days of payoff (ORC 5301.36)."""@en .

cincy:satisfactionDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:date ;
    rdfs:label "satisfaction date"@en ;
    rdfs:comment "The date the mortgage was satisfied (paid in full)."@en .

cincy:lienPriority
    a owl:DatatypeProperty ;
    rdfs:domain cincy:Mortgage ;
    rdfs:range xsd:integer ;
    rdfs:label "lien priority"@en ;
    rdfs:comment """The priority position of this mortgage lien (1 = first
    mortgage, 2 = second mortgage, etc.). Priority follows recording order
    under Ohio's race-notice statute unless altered by a subordination
    agreement. Purchase money mortgages have automatic priority over
    liens attaching at the time of acquisition."""@en .

# --- Ownership Interest ---

cincy:interestFraction
    a owl:DatatypeProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range xsd:decimal ;
    rdfs:label "interest fraction"@en ;
    rdfs:comment """The fractional share of ownership, expressed as a decimal
    (e.g., 0.5 for a 50% interest). For tenancy in common, shares need not
    be equal. For survivorship tenancy, shares are typically equal."""@en .

cincy:interestStartDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range xsd:date ;
    rdfs:label "interest start date"@en ;
    rdfs:comment "The date this ownership interest was established."@en .

cincy:interestEndDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:OwnershipInterest ;
    rdfs:range xsd:date ;
    rdfs:label "interest end date"@en ;
    rdfs:comment "The date this ownership interest terminated (transfer, death, etc.)."@en .

# --- Heirs' Property ---

cincy:decedentDeathDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:date ;
    rdfs:label "decedent death date"@en ;
    rdfs:comment "Date of death of the owner of record, if known."@en .

cincy:estimatedHeirCount
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:integer ;
    rdfs:label "estimated heir count"@en ;
    rdfs:comment """Estimated number of potential heirs with a fractional interest
    by operation of intestate succession. May span multiple generations."""@en .

cincy:isOccupiedByHeir
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:boolean ;
    rdfs:label "occupied by heir"@en ;
    rdfs:comment "True if one or more heirs are currently occupying the property."@en .

cincy:heirsPropertyIdentifiedDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:date ;
    rdfs:label "heirs' property identified date"@en ;
    rdfs:comment "Date the property was identified or flagged as heirs' property."@en .

cincy:isTitleCleared
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:boolean ;
    rdfs:label "title cleared"@en ;
    rdfs:comment """True if the tangled title has been resolved through probate,
    heirship affidavit, quiet title action, or other legal proceeding."""@en .

cincy:titleClearedDate
    a owl:DatatypeProperty ;
    rdfs:domain cincy:HeirsPropertyDesignation ;
    rdfs:range xsd:date ;
    rdfs:label "title cleared date"@en ;
    rdfs:comment "Date the title was cleared, if resolved."@en .

cincy:sketchIdCode
    a owl:ObjectProperty ;
    rdfs:domain cincy:ParcelYearState ;
    rdfs:range cincy:SketchIdCode ;
    rdfs:label "sketch ID code"@en ;
    rdfs:comment "Links a parcel year state to a sketch ID code describing an attached addition, detached addition, or story height (see cincy-sketch-id-codes.ttl)."@en .

# --- Rental registration ---

cincy:rentalContactName
    a owl:DatatypeProperty ;
    rdfs:domain cincy:RentalRegistration ;
    rdfs:range xsd:string ;
    rdfs:label "rental contact person name"@en ;
    rdfs:comment "Extracted via OCR from the rental registration PDF."@en .

cincy:rentalRegistrationYear
    a owl:DatatypeProperty ;
    rdfs:domain cincy:RentalRegistration ;
    rdfs:range xsd:gYear ;
    rdfs:label "rental registration year"@en .

# --- Board of Revision ---

cincy:disputeYear
    a owl:DatatypeProperty ;
    rdfs:domain cincy:BoardOfRevisionDispute ;
    rdfs:range xsd:gYear ;
    rdfs:label "dispute year"@en ;
    rdfs:comment "Year the owner went before the Board of Revision. Disputed value details are not available (trapped in PDFs)."@en .

# --- Census geography ---

cincy:tractGEOID
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain cincy:CensusTract ;
    rdfs:range xsd:string ;
    rdfs:label "census tract GEOID"@en ;
    rdfs:comment "11-digit Census GEOID: 2-digit state FIPS + 3-digit county FIPS + 6-digit tract code. Example: 39061002700 (Ohio, Hamilton County, tract 0027.00)."@en .

cincy:tractNumber
    a owl:DatatypeProperty ;
    rdfs:domain cincy:CensusTract ;
    rdfs:range xsd:string ;
    rdfs:label "census tract number"@en ;
    rdfs:comment "6-digit tract code as published by the Census Bureau (e.g., 002700 for tract 0027.00)."@en .

cincy:blockGEOID
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain cincy:CensusBlock ;
    rdfs:range xsd:string ;
    rdfs:label "census block GEOID"@en ;
    rdfs:comment "15-digit Census GEOID: 2-digit state FIPS + 3-digit county FIPS + 6-digit tract code + 4-digit block number. Example: 390610027001001."@en .

cincy:blockNumber
    a owl:DatatypeProperty ;
    rdfs:domain cincy:CensusBlock ;
    rdfs:range xsd:string ;
    rdfs:label "census block number"@en ;
    rdfs:comment "4-digit block number within its census tract (e.g., 1001)."@en .

# --- Tax delinquency ---

cincy:delinquentAmount
    a owl:DatatypeProperty ;
    rdfs:domain cincy:DelinquencyRecord ;
    rdfs:range xsd:integer ;
    rdfs:label "delinquent amount (USD)"@en ;
    rdfs:comment """The total unpaid tax balance flagged by the Auditor at the time
    of the delinquency designation. May include penalty assessed on the past-due
    installment(s)."""@en .

cincy:delinquentYear
    a owl:DatatypeProperty ;
    rdfs:domain cincy:DelinquencyRecord ;
    rdfs:range xsd:gYear ;
    rdfs:label "delinquent year"@en ;
    rdfs:comment """The tax year in which the unpaid balance survived Treasurer
    end-of-year reconciliation and the parcel was placed on the delinquent land
    list."""@en .

cincy:isUnderRepaymentContract
    a owl:DatatypeProperty ;
    rdfs:domain cincy:DelinquencyRecord ;
    rdfs:range xsd:boolean ;
    rdfs:label "under repayment contract"@en ;
    rdfs:comment """True if the owner has entered a formal delinquent tax repayment
    contract with the Auditor. A parcel under contract is still delinquent but
    protected from active foreclosure proceedings while payments are current."""@en .

# --- TIF District ---

cincy:baseYear
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TIFDistrict ;
    rdfs:range xsd:gYear ;
    rdfs:label "TIF base year"@en .

cincy:districtCode
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range xsd:string ;
    rdfs:label "district code"@en ;
    rdfs:comment "3-digit Hamilton County tax district code."@en .

cincy:schoolDistrictCode
    a owl:DatatypeProperty ;
    rdfs:domain cincy:SchoolDistrict ;
    rdfs:range xsd:string ;
    rdfs:label "school district IRN code"@en ;
    rdfs:comment "5-digit Ohio IRN (Institution Revenue Number) for the school district."@en .

cincy:appraisalAreaCode
    a owl:DatatypeProperty ;
    rdfs:domain cincy:AppraisalArea ;
    rdfs:range xsd:string ;
    rdfs:label "appraisal area code"@en ;
    rdfs:comment "5-digit appraisal area code assigned by the Hamilton County Auditor."@en .

cincy:municipalityName
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range xsd:string ;
    rdfs:label "municipality name"@en ;
    rdfs:comment "Name of the incorporated city or village within this tax district, if any."@en .

cincy:townshipName
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range xsd:string ;
    rdfs:label "township name"@en ;
    rdfs:comment "Name of the township within this tax district, if any."@en .

cincy:fireDivisionName
    a owl:DatatypeProperty ;
    rdfs:domain cincy:TaxDistrict ;
    rdfs:range xsd:string ;
    rdfs:label "fire division name"@en ;
    rdfs:comment "Name of the fire district serving this tax district, if it differs from the municipality/township fire service."@en .
